<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.devpilot.mapper.NoteTagMapper">

    <!--
        批量插入标签关联
        使用 INSERT IGNORE 跳过已存在的 note_id + tag_id 组合（由 uk_note_tag 唯一索引保证）
    -->
    <insert id="batchInsert">
        INSERT INTO t_note_tag (note_id, tag_id, created_at)
        VALUES
        <foreach collection="tagIds" item="tagId" separator=",">
            (#{noteId}, #{tagId}, NOW())
        </foreach>
    </insert>

    <!-- 按笔记 ID 删除所有标签关联 -->
    <delete id="deleteByNoteId">
        DELETE FROM t_note_tag WHERE note_id = #{noteId}
    </delete>

</mapper>

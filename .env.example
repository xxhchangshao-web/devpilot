# DevPilot 生产环境变量模板
# 复制为 .env 后必须修改所有 CHANGE_ME 项

# 数据库
POSTGRES_DB=devpilot
POSTGRES_USER=devpilot
POSTGRES_PASSWORD=CHANGE_ME_STRONG_DATABASE_PASSWORD

# 后端
DB_HOST=postgres
DB_PORT=5432
DB_NAME=devpilot
DB_USERNAME=devpilot
DB_PASSWORD=CHANGE_ME_STRONG_DATABASE_PASSWORD
JWT_SECRET=CHANGE_ME_AT_LEAST_32_RANDOM_CHARS
SPRING_PROFILES_ACTIVE=prod

# 管理员账号：仅用于你本人，不要公开
ADMIN_USERNAME=admin
ADMIN_PASSWORD=CHANGE_ME_STRONG_ADMIN_PASSWORD

# 公开演示账号：只读 VIEWER
DEMO_PASSWORD=DevPilotDemo2026!

# 生产 CORS：无域名时填写 http://服务器公网IP
CORS_ALLOWED_ORIGINS=http://47.107.151.225
